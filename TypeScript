school.addStudent(st2);
school.addStudent(new StudentClass("Максим", 19, "спорт", "C", 3));

console.log(school.listNames()); // string[]
console.log(school.countByFacultative("спорт")); // проверка


// 13.
type SchoolEvent =
  | { type: "add"; student: StudentClass }
  | { type: "remove"; name: string };

function handleEvent(school: School, event: SchoolEvent): void {
  if (event.type === "add") {
    school.addStudent(event.student);
  } else if (event.type === "remove") {
    school.removeByName(event.name);
  }
}

handleEvent(school, { type: "add", student: new StudentClass("Сергей", 16, "игры", "A", 1) });
handleEvent(school, { type: "remove", name: "Елена" });


// 15.
function nextLevel(level: Level): Level {
  if (level < 4) {
    return (level + 1) as Level;
  }
  return 4;
}

const newLevel = nextLevel(3); // 4
console.log(newLevel);
