// 7. 
class StudentClass {
  name: string;
  age: Age;
  facultative: Facultative;
  group: Group;
  level: Level;

  constructor(name: string, age: Age, facultative: Facultative, group: Group, level: Level) {
    this.name = name;
    this.age = age;
    this.facultative = facultative;
    this.group = group;
    this.level = level;
  }

  // 8.
  info(): string {
    return '${this.name}, ${this.age}, ${this.facultative}';
  }
}

